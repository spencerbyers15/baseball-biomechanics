<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.spencerbyers.fvcapture</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/spencerbyers/anaconda3/envs/baseball/bin/python</string>
        <string>-u</string>
        <string>/Users/spencerbyers/fieldvision/scripts/fv_daemon.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/spencerbyers/fieldvision</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>/Users/spencerbyers/fieldvision/scheduler.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/spencerbyers/fieldvision/scheduler.err</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/spencerbyers</string>
        <key>USER</key>
        <string>spencerbyers</string>
        <key>PATH</key>
        <string>/Users/spencerbyers/anaconda3/envs/baseball/bin:/Users/spencerbyers/anaconda3/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
